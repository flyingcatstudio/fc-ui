{
  "name": "@fcstudio/fc-ui",
  "version": "0.1.0",
  "description": "Flying Cat UI — theme-aware React component library. Swap a single provider and reskin every component (Dashboard, Glass, 8-bit, or your own).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "lucide-react": ">=0.300",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "vite": "^5.4.0"
  },
  "scripts": {
    "dev": "vite examples",
    "build": "tsup",
    "preview": "vite preview examples"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "theme",
    "glass",
    "8bit",
    "dashboard"
  ],
  "author": "Hyun",
  "license": "MIT",
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
